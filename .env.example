# ── Base de datos (PostgreSQL) ────────────────────────────────────────────────
POSTGRES_DB=security_scans
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Dashboard ─────────────────────────────────────────────────────────────────
DB_HOST=postgres-scans
DB_NAME=security_scans
DB_USER=
DB_PASSWORD=
DB_PORT=5432

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_ENCRYPTION_KEY=
WEBHOOK_URL=http://<VM_IP>:5678/

# ── GVM / OpenVAS ─────────────────────────────────────────────────────────────
GVM_USER=
GVM_PASSWORD=

# ── n8n autenticación ─────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=

# ── Integración dashboard → n8n ───────────────────────────────────────────────
N8N_WEBHOOK_URL=http://n8n:5678/webhook/start-scan

# ── Red de laboratorio ────────────────────────────────────────────────────────
SCAN_NETWORK=192.168.100.0/24

# ── Zona horaria ──────────────────────────────────────────────────────────────
TZ=America/Argentina/Buenos_Aires
